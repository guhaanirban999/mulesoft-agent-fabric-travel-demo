# =============================================================================
# deploy.env.template
# Environment variables for deploy-to-org.sh
#
# Usage:
#   cp deploy.env.template deploy.env
#   vi deploy.env          # fill in all <...> placeholders
#   source deploy.env
#   chmod +x deploy-to-org.sh
#   ./deploy-to-org.sh
#
# SECURITY: deploy.env is listed in .gitignore – never commit it.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 1. TARGET ORG – Anypoint Connected App credentials
# ─────────────────────────────────────────────────────────────────────────────
# Create a Connected App in the TARGET org:
#   Anypoint Platform → Access Management → Connected Apps → Create App
#   Type: App acts on its own behalf (client credentials)
#   Required scopes:
#     - Exchange Contributor
#     - Exchange Viewer
#     - Design Center Developer
#     - API Manager Environment Administrator
#     - General Profile Access (or Organization Administrator)
#     - Agent Network Administrator  (if available in your org)

export TARGET_CLIENT_ID="<target-org-connected-app-client-id>"
export TARGET_CLIENT_SECRET="<target-org-connected-app-client-secret>"

# ─────────────────────────────────────────────────────────────────────────────
# 2. TARGET ORG / ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────
# Organization (root or business group) ID of the target org.
# Anypoint Platform → Access Management → <org name> → Settings → Organization ID
export TARGET_ORG_ID="<target-org-uuid>"

# Anypoint environment name inside the target org (case-sensitive).
# Common values: Sandbox, Production, Dev
export TARGET_ENV_NAME="Sandbox"

# ─────────────────────────────────────────────────────────────────────────────
# 3. FLEX GATEWAY / PRIVATE SPACE
# ─────────────────────────────────────────────────────────────────────────────
# Name of the Managed Flex Gateway registered in the target org.
# Anypoint Platform → Runtime Manager → Flex Gateways → <gateway name>
export TARGET_FLEX_GW_NAME="<flex-gateway-name>"

# Private Space (CloudHub 2.0) or Runtime Fabric space name where
# the Flex Gateway is running.
export TARGET_PRIVATE_SPACE="<private-space-name>"

# ─────────────────────────────────────────────────────────────────────────────
# 4. CONNECTION VARIABLES
# These map to the ${...} placeholders in agent-network.yaml and are declared
# as metadata.variables in exchange.json.
# ─────────────────────────────────────────────────────────────────────────────

# ingressgw.url
# The base URL of the Flex Gateway ingress in the target org.
# The broker will be reachable at  <INGRESSGW_URL>/travel-agent-broker
# Example: https://my-flex-gw.eu1.cloudhub.io
export INGRESSGW_URL="https://<flex-gateway-ingress-hostname>"

# openai.url
# OpenAI API base URL.  Default: https://api.openai.com/v1
# Change only if you are using Azure OpenAI or a custom proxy.
export OPENAI_URL="https://api.openai.com/v1"

# openai.apiKey
# Your OpenAI API key (sk-proj-...).  Treated as a secret.
export OPENAI_API_KEY="sk-proj-<your-openai-api-key>"

# flightBookingAgent.url
# A2A (Agent-to-Agent) endpoint URL of the Flight Booking Agent deployed
# in the target org.  Deploy that agent first, then paste its URL here.
# Example: https://flight-agent.eu1.cloudhub.io/flight-booking-agent
export FLIGHT_BOOKING_AGENT_URL="https://<flight-booking-agent-a2a-endpoint>"

# hotelBookingAgent.url
# A2A endpoint URL of the Hotel Booking Agent deployed in the target org.
# Deploy that agent first, then paste its URL here.
# Example: https://hotel-agent.eu1.cloudhub.io/hotel-booking-agent
export HOTEL_BOOKING_AGENT_URL="https://<hotel-booking-agent-a2a-endpoint>"

# ─────────────────────────────────────────────────────────────────────────────
# 5. OPTIONAL OVERRIDES
# ─────────────────────────────────────────────────────────────────────────────

# Exchange version group (increment to v2, v3 ... for subsequent major releases)
export VERSION_GROUP="v1"

# Asset version published to Exchange (default matches exchange.json)
export ASSET_VERSION="1.0.0"

# Absolute path to the project root (defaults to the directory of deploy-to-org.sh)
# Uncomment only if running the script from a different directory.
# export PROJECT_PATH="/path/to/travel-agent-broker"

# Override the Anypoint CLI binary name / path
# export ANYPOINT_CLI="anypoint-cli-v4"